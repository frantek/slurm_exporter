        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_reservation_nodes_healthy",
          "legendFormat": "{{reservation}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "bargauge",
      "id": 31,
      "title": "Node States per Reservation",
      "gridPos": {
        "h": 8,
