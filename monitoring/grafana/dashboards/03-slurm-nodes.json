                  {
                    "type": "value",
                    "options": {
                      "down": {
                        "color": "red",
                        "text": "down"
                      },
                      "drain": {
                        "color": "purple",
                        "text": "drain"
                      },
                      "drained": {
                        "color": "purple",
                        "text": "drained"
                      },
                      "fail": {
                        "color": "dark-red",
                        "text": "fail"
                      },
                      "unknown": {
