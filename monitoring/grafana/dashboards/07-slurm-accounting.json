      "id": 3,
      "title": "CPUs Running",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_jobs_cores_running",
          "legendFormat": "CPUs",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "stat",
      "id": 4,
      "title": "Active Users",
      "description": "Number of users with at least one running job.",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(slurm_user_jobs_running > 0) or vector(0)",
          "legendFormat": "Active Users",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "stat",
      "id": 5,
      "title": "Active Accounts",
      "description": "Number of accounts with at least one running job.",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "cyan"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "cyan",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(slurm_account_jobs_running{account!~\"none|root\"} > 0) or vector(0)",
          "legendFormat": "Active Accounts",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Top Consumers (current jobs)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "bargauge",
      "id": 10,
      "title": "Top Users — Running Jobs",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 5
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(15, slurm_user_jobs_running)",
          "legendFormat": "{{user}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "bargauge",
      "id": 11,
      "title": "Top Users — Running CPUs",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 5
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "orange",
                "value": 64
              },
              {
                "color": "red",
                "value": 256
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(15, slurm_user_cpus_running)",
          "legendFormat": "{{user}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "bargauge",
      "id": 12,
      "title": "Top Accounts — Running CPUs",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 5
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "orange",
                "value": 128
              },
              {
                "color": "red",
                "value": 512
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(10, slurm_account_cpus_running{account!~\"none|root\"})",
          "legendFormat": "{{account}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "FairShare Analysis — Why is my priority low?",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 13
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "text",
      "id": 20,
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "options": {
        "content": "> **FairShare** (0–1): lower = lower priority. Determined by `NormUsage / NormShares`. **Usage/Shares ratio > 1** means a user consumed more than their allocation → expect declining priority. **< 1** means underused → priority increasing.",
        "mode": "markdown"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "table",
      "id": 21,
      "title": "User FairShare Summary",
      "description": "FairShare factor, shares allocation and historical CPU usage per user. Filter by account using the variable above.",
      "gridPos": {
        "h": 10,
        "w": 14,
        "x": 0,
        "y": 16
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "FairShare"
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "FairShare"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "decimals",
                "value": 1
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              },
              {
                "id": "max",
                "value": 1
              },
              {
                "id": "min",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 0.3
                    },
                    {
                      "color": "green",
                      "value": 0.7
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "NormUsage/NormShares"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 0.8
                    },
                    {
                      "color": "red",
                      "value": 1.2
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CPU-seconds (hist.)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "decimals",
                "value": 0
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true,
              "__name__": true
            },
            "renameByName": {
              "user": "User",
              "account": "Account",
              "Value #A": "FairShare",
              "Value #B": "NormShares",
              "Value #C": "NormUsage",
              "Value #D": "NormUsage/NormShares",
              "Value #E": "CPU-seconds (hist.)"
            }
          }
        }
      ],
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_user_fairshare{account=~\"${account:regex}\"}",
          "legendFormat": "{{user}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_user_fairshare_norm_shares{account=~\"${account:regex}\"}",
          "legendFormat": "{{user}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_user_fairshare_norm_usage{account=~\"${account:regex}\"}",
          "legendFormat": "{{user}}",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_user_fairshare_norm_usage{account=~\"${account:regex}\"} / clamp_min(slurm_user_fairshare_norm_shares{account=~\"${account:regex}\"}, 0.0001)",
          "legendFormat": "{{user}}",
          "refId": "D",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_user_fairshare_raw_usage_cpu_seconds{account=~\"${account:regex}\"}",
          "legendFormat": "{{user}}",
          "refId": "E",
          "instant": true,
          "format": "table"
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "bargauge",
      "id": 22,
      "title": "Users by FairShare (lowest = most deprived)",
      "description": "Sorted ascending — users at the top have the lowest priority. A low FairShare means they have consumed more than their allocated share.",
      "gridPos": {
        "h": 10,
        "w": 10,
        "x": 14,
        "y": 16
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sort(slurm_user_fairshare{account=~\"${account:regex}\"})",
          "legendFormat": "{{user}} ({{account}})",
          "refId": "A",
          "instant": true
        }
      ]
    },
