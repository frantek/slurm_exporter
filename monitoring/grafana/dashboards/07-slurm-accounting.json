      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "bargauge",
      "name": "Bar gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "row",
      "name": "Row",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "HPC accounting: user and account resource consumption, FairShare analysis, top consumers, and priority diagnostics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "slurm"
      ],
      "targetBlank": false,
      "title": "Slurm Dashboards",
      "tooltip": "Switch to another Slurm dashboard",
      "type": "dashboards",
      "url": ""
    },
    {
      "title": "slurm_exporter on GitHub",
      "url": "https://github.com/SckyzO/slurm_exporter",
      "type": "link",
      "icon": "external link",
      "tooltip": "View source, docs and dashboards on GitHub",
      "targetBlank": true,
      "tags": [],
      "asDropdown": false,
      "includeVars": false,
      "keepTime": false
    }
  ],
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Current Activity",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "stat",
      "id": 1,
      "title": "Running Jobs",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "slurm_jobs_running",
          "legendFormat": "Running",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "type": "stat",
      "id": 2,
